# Copy to .env and fill in values

# Path to credentials.json downloaded from GCP Console
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Path where OAuth2 token will be stored after first auth
GOOGLE_TOKEN_PATH=./token.json

# Google Drive folder ID to crawl
DRIVE_ROOT_FOLDER_ID=1Z-Bqt69UgrGkwo0ArjHaNrA7uUmUm2r6

# Backend port
PORT=3000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Set to true to run without Google credentials (serves built-in seed data)
DEMO_MODE=false
